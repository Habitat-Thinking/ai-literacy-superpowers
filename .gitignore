# Harness upgrade dismissal marker — local session state, not committed
.claude/.harness-upgrade-dismissed

# Discovery scanner output — per-session drafts that are reviewed and
# (if approved) copied into HARNESS.md by hand. Never committed.
.claude/affordance-discovery-*.md

# Affordance runtime invocation log — per-machine, append-only NDJSON written
# by the PostToolUse recorder hook. Gitignored to dissolve the cross-machine
# merge problem; it answers "did MY sessions invoke this?" locally.
observability/affordance-invocations.json

_site/
site/

# Python build artefacts (tdad_tests/ test suite). The venv, pytest
# cache, byte-compiled modules, and editable-install metadata are all
# per-developer and should not be committed.
**/.venv/
**/__pycache__/
**/.pytest_cache/
**/*.egg-info/

# Diagnostic Legibility reports — derived, regenerable artefacts written
# by the /diagnose command. Never committed nor rsynced into the plugin
# cache (S4 spec §7.2 / O3).
diagnostic-legibility/output/

# Vendored Mermaid bundle cache — the /pipeline-map command fetches the
# pinned, SHA-verified Mermaid bundle here on first use and reuses it.
# Derived/regenerable from the manifest (assets/mermaid-vendor.md), never
# committed (pipeline-map spec §2.2 revised at P5: pin+SHA+cache, not a
# committed blob).
diagnostic-legibility/assets/cache/

# Cost estimate records — derived, regenerable artefacts written by the
# /cost-estimate command. An estimate references a moving target (an
# unmerged spec, a since-renamed slice, changing task text), so it is
# regenerated on demand, not committed. Never committed.
cost-estimates/

.DS_Store
